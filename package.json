{
  "name": "loopboard-todo",
  "displayName": "LoopBoard TODO",
  "description": "Renders the workspace TODO.md as an interactive board and spawns coding-agent loop terminals (Claude Code today).",
  "version": "2.0.1",
  "publisher": "SinnConsulting",
  "preview": true,
  "license": "MIT",
  "icon": "media/loopboard-icon-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SinnConsulting/LoopBoard.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:.loopboard/TODO.md"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "loopboard",
          "title": "LoopBoard",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "loopboard": [
        {
          "id": "loopBoard.sidebar",
          "name": "LoopBoard",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "loopBoard.openBoard",
        "title": "LoopBoard: Open Board"
      },
      {
        "command": "loopBoard.refresh",
        "title": "LoopBoard: Refresh"
      },
      {
        "command": "loopBoard.spawnLoop",
        "title": "LoopBoard: Start Loop"
      },
      {
        "command": "loopboard.init",
        "title": "LoopBoard: Initialize Workspace"
      }
    ],
    "configuration": {
      "title": "LoopBoard",
      "properties": {
        "loopBoard.permissionMode": {
          "type": "string",
          "enum": [
            "auto",
            "acceptEdits",
            "bypassPermissions",
            "dontAsk",
            "default",
            "plan"
          ],
          "default": "auto",
          "description": "--permission-mode passed to the claude CLI when spawning a loop terminal."
        },
        "loopBoard.defaultModel": {
          "type": "string",
          "enum": [
            "opus",
            "sonnet",
            "fable",
            "haiku"
          ],
          "default": "opus",
          "description": "The model that owns tasks with no explicit model: field."
        },
        "loopBoard.models": {
          "type": "object",
          "default": {},
          "additionalProperties": false,
          "markdownDescription": "Per-model overrides. Each built-in slot (opus/sonnet/fable/haiku) accepts either a plain STRING — a shorthand for the `--model` string to spawn (e.g. `\"haiku\": \"haiku[1m]\"`) — or an OBJECT `{ \"enabled\": bool, \"model\": string }` for full control (set `enabled: false` to hide the slot from the Loops overview and the board's model selects). A custom `--model` replaces the default when non-empty; invalid `--model` strings are ignored.",
          "properties": {
            "opus": {
              "anyOf": [
                { "type": "string", "description": "Custom --model string (shorthand)." },
                { "type": "object", "additionalProperties": false, "properties": {
                  "enabled": { "type": "boolean", "default": true, "description": "Show this model in the Loops overview and selects." },
                  "model": { "type": "string", "default": "", "description": "Custom --model string (empty = default 'opus')." }
                } }
              ]
            },
            "sonnet": {
              "anyOf": [
                { "type": "string", "description": "Custom --model string (shorthand)." },
                { "type": "object", "additionalProperties": false, "properties": {
                  "enabled": { "type": "boolean", "default": true, "description": "Show this model in the Loops overview and selects." },
                  "model": { "type": "string", "default": "", "description": "Custom --model string (empty = default 'sonnet')." }
                } }
              ]
            },
            "fable": {
              "anyOf": [
                { "type": "string", "description": "Custom --model string (shorthand)." },
                { "type": "object", "additionalProperties": false, "properties": {
                  "enabled": { "type": "boolean", "default": true, "description": "Show this model in the Loops overview and selects." },
                  "model": { "type": "string", "default": "", "description": "Custom --model string (empty = default 'fable')." }
                } }
              ]
            },
            "haiku": {
              "anyOf": [
                { "type": "string", "description": "Custom --model string (shorthand)." },
                { "type": "object", "additionalProperties": false, "properties": {
                  "enabled": { "type": "boolean", "default": true, "description": "Show this model in the Loops overview and selects." },
                  "model": { "type": "string", "default": "", "description": "Custom --model string (empty = default 'haiku')." }
                } }
              ]
            }
          }
        },
        "loopBoard.loopInterval": {
          "type": "string",
          "default": "1m",
          "description": "Interval passed to /loop (e.g. 1m, 5m)."
        },
        "loopBoard.autoRecycle": {
          "type": "boolean",
          "default": false,
          "description": "When a model finishes a task, restart its loop terminal (close it and open a new one) so the next task starts fresh. The heavier of the two fresh-context options. Off by default; restart manually with ♻."
        },
        "loopBoard.clearSessionAfterTask": {
          "type": "boolean",
          "default": false,
          "description": "When a model finishes a task, send /clear to its loop terminal so the next task starts fresh. Same result as Auto Recycle but lighter: the terminal keeps running, only the conversation is cleared. Off by default. Ignored when Auto Recycle is on (a restart already clears everything)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --test 'test/*.test.js'"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/vscode": "^1.90.0"
  }
}
